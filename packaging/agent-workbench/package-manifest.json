{
  "name": "agent-workbench",
  "version": "0.5.2",
  "registry": "ghcr.io",
  "distribution": {
    "npm_contract": "packaging/agent-workbench/npm-package.json",
    "npm_package": "@auriora/agent-workbench",
    "npm_publish_status": "github-release"
  },
  "image": "ghcr.io/bcherrington/agent-workbench",
  "containerfile": "packaging/agent-workbench/Containerfile",
  "install_command": "npm install -g https://github.com/Auriora/agent-workbench/releases/download/v0.5.2/auriora-agent-workbench-0.5.2.tgz",
  "npm_bin": "packaging/agent-workbench/mcp-bin.mjs",
  "entrypoint": "node --import tsx /opt/agent-workbench/src/mcp/stdio.ts",
  "dependency_install": {
    "package_manager": "pnpm@10.18.1",
    "node": ">=22",
    "install_command": "pnpm install --frozen-lockfile",
    "native_rebuild_command": "pnpm rebuild:native",
    "native_build_tools": [
      "python3",
      "make",
      "c++"
    ],
    "runtime_dependencies": [
      "@modelcontextprotocol/sdk",
      "@opentelemetry/api",
      "@opentelemetry/exporter-trace-otlp-http",
      "@opentelemetry/resources",
      "@opentelemetry/sdk-trace-base",
      "@opentelemetry/sdk-trace-node",
      "@opentelemetry/semantic-conventions",
      "better-sqlite3",
      "tree-sitter",
      "tree-sitter-go",
      "tree-sitter-javascript",
      "tree-sitter-python",
      "tree-sitter-typescript",
      "tsx",
      "yaml",
      "zod"
    ],
    "dev_dependencies": [
      "@types/better-sqlite3",
      "@types/node",
      "typescript",
      "vitest"
    ],
    "native_build_script_dependencies": [
      "better-sqlite3",
      "esbuild",
      "tree-sitter",
      "tree-sitter-go",
      "tree-sitter-javascript",
      "tree-sitter-python",
      "tree-sitter-typescript"
    ]
  },
  "components": [
    "src",
    "docs",
    "plugins/agent-workbench",
    "plugins/agent-workbench/claude-plugin",
    "plugins/agent-workbench/hooks",
    "plugins/agent-workbench/kiro-power",
    "plugins/agent-workbench/skills",
    "scripts/install-codex-hooks.mjs",
    "package.json",
    "LICENSE",
    "pnpm-lock.yaml",
    "tsconfig.json",
    "AGENTS.md",
    "CLAUDE.md"
  ],
  "excluded_components": [
    "docs/specs",
    "src/debug",
    "package.json scripts matching debug:*"
  ],
  "codex": {
    "mcp_server_id": "agent-workbench",
    "plugin_manifest": "plugins/agent-workbench/.codex-plugin/plugin.json",
    "plugin_mcp_config": "plugins/agent-workbench/.mcp.json",
    "hook_installer": "scripts/install-codex-hooks.mjs",
    "plugin_install_model": "npm install -g https://github.com/Auriora/agent-workbench/releases/download/v0.5.2/auriora-agent-workbench-0.5.2.tgz"
  },
  "kiro": {
    "power_root": "plugins/agent-workbench/kiro-power",
    "power_manifest": "plugins/agent-workbench/kiro-power/POWER.md",
    "power_mcp_config": "plugins/agent-workbench/kiro-power/mcp.json",
    "power_skill": "plugins/agent-workbench/kiro-power/skills/agent-workbench/SKILL.md",
    "power_agent_config": "plugins/agent-workbench/kiro-power/agents/agent-workbench.json",
    "power_hooks": [
      "plugins/agent-workbench/kiro-power/.kiro/hooks/agent-workbench-ready-check.kiro.hook",
      "plugins/agent-workbench/kiro-power/.kiro/hooks/agent-workbench-post-write-feedback.kiro.hook",
      "plugins/agent-workbench/kiro-power/hooks/session-start.js",
      "plugins/agent-workbench/kiro-power/hooks/post-edit-feedback.js"
    ],
    "install_model": "Add the local Power directory in Kiro after installing the package-backed runtime."
  },
  "claude_code": {
    "plugin_root": "plugins/agent-workbench/claude-plugin",
    "plugin_manifest": "plugins/agent-workbench/claude-plugin/.claude-plugin/plugin.json",
    "plugin_mcp_config": "plugins/agent-workbench/claude-plugin/.mcp.json",
    "plugin_project_guidance": "plugins/agent-workbench/claude-plugin/CLAUDE.md",
    "plugin_skill": "plugins/agent-workbench/claude-plugin/skills/agent-workbench/SKILL.md",
    "plugin_hooks": "plugins/agent-workbench/claude-plugin/hooks/hooks.json",
    "plugin_hook_scripts": [
      "plugins/agent-workbench/claude-plugin/hooks/session-start.js",
      "plugins/agent-workbench/claude-plugin/hooks/post-edit-feedback.js"
    ],
    "install_model": "Install the runtime from the GitHub release tarball (`npm install -g <release-url>`; see docs/runbooks/install-agent-workbench.md), then register the bundled Claude plugin: `claude plugin marketplace add <package>/plugins/agent-workbench` then `claude plugin install agent-workbench@agent-workbench-local --scope user`."
  }
}
