{
  "package_name": "@auriora/agent-workbench",
  "registry": "npm",
  "publish_status": "pack-ready-not-published",
  "version_source": "package.json#/version",
  "plugin_version_source": "plugins/agent-workbench/.codex-plugin/plugin.json#/version",
  "install_command": "npx @auriora/agent-workbench install",
  "pack_command": "npm pack",
  "payload_root": "plugins/agent-workbench",
  "bin": "packaging/agent-workbench/npm-install.js",
  "required_paths": [
    "AGENTS.md",
    "README.md",
    "docs/runbooks/codex-agent-workbench-plugin.md",
    "docs/design/coding-agent-integration-design.md",
    "docs/design/runtime-operations-design.md",
    "docs/reference/agent-readable-changelog.md",
    "docs/reference/dogfood-evidence-ledger.md",
    "docs/reference/lifecycle-bridge-contract.md",
    "docs/reference/runtime-contracts.md",
    "docs/security/threat-model.md",
    "package.json",
    "packaging/agent-workbench/npm-package.json",
    "packaging/agent-workbench/npm-install.js",
    "packaging/agent-workbench/package-manifest.json",
    "plugins/agent-workbench/.codex-plugin/plugin.json",
    "plugins/agent-workbench/.mcp.json",
    "plugins/agent-workbench/hooks/hooks.json",
    "plugins/agent-workbench/hooks/session-start.js",
    "plugins/agent-workbench/hooks/post-edit-feedback.js",
    "plugins/agent-workbench/claude-plugin/.claude-plugin/plugin.json",
    "plugins/agent-workbench/claude-plugin/.mcp.json",
    "plugins/agent-workbench/claude-plugin/hooks/hooks.json",
    "plugins/agent-workbench/claude-plugin/skills/agent-workbench/SKILL.md",
    "plugins/agent-workbench/kiro-power/POWER.md",
    "plugins/agent-workbench/kiro-power/mcp.json",
    "plugins/agent-workbench/kiro-power/skills/agent-workbench/SKILL.md",
    "plugins/agent-workbench/skills/agent-workbench/SKILL.md",
    "pnpm-lock.yaml",
    "scripts/install-agent-workbench-package.sh",
    "src/mcp/stdio-entrypoint.mjs",
    "src/mcp/stdio.ts",
    "tsconfig.json"
  ],
  "provenance": {
    "source_repository": "https://github.com/Auriora/agent-workbench",
    "source_path": "plugins/agent-workbench",
    "commit_source": "git HEAD when packed",
    "validation_command": "npm_config_cache=/tmp/agent-workbench-npm-cache npm pack --dry-run --json"
  }
}
