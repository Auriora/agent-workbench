{
  "name": "@auriora/agent-workbench",
  "version": "0.5.1",
  "type": "module",
  "packageManager": "pnpm@10.18.1",
  "description": "Local-first Agent IDE runtime scaffold.",
  "license": "GPL-3.0-or-later",
  "author": "Auriora",
  "homepage": "https://github.com/Auriora/agent-workbench/tree/main/plugins/agent-workbench",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Auriora/agent-workbench.git"
  },
  "keywords": [
    "codex",
    "plugin",
    "mcp",
    "agent",
    "workbench"
  ],
  "bin": {
    "agent-workbench-mcp": "packaging/agent-workbench/mcp-bin.mjs"
  },
  "files": [
    "AGENTS.md",
    "CLAUDE.md",
    "LICENSE",
    "README.md",
    "docs/design/coding-agent-integration-design.md",
    "docs/design/runtime-operations-design.md",
    "docs/reference/agent-readable-changelog.md",
    "docs/reference/dogfood-evidence-ledger.md",
    "docs/reference/lifecycle-bridge-contract.md",
    "docs/reference/runtime-contracts.md",
    "docs/security/threat-model.md",
    "docs/runbooks/codex-agent-workbench-plugin.md",
    "package.json",
    "packaging/agent-workbench/package-manifest.json",
    "packaging/agent-workbench/npm-package.json",
    "packaging/agent-workbench/mcp-bin.mjs",
    "plugins/agent-workbench",
    "scripts/install-codex-hooks.mjs",
    "scripts/postinstall.mjs",
    "scripts/rebuild-native.mjs",
    "src",
    "tsconfig.json"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:devcli": "python3 -m unittest discover -s tools/devcli/tests",
    "dev": "tsx src/index.ts",
    "mcp": "node src/mcp/stdio-entrypoint.mjs",
    "postinstall": "node scripts/postinstall.mjs",
    "debug:mcp-status": "tsx src/debug/mcp-status.ts",
    "debug:mcp-use-case": "tsx src/debug/mcp-use-case.ts",
    "debug:mcp-profile": "tsx src/debug/mcp-use-case.ts --profile",
    "debug:sample-smoke": "tsx src/debug/sample-smoke.ts",
    "debug:mcp-tool-sweep": "tsx src/debug/mcp-tool-sweep.ts",
    "validate:plugin": "node scripts/validate-agent-workbench-plugin.mjs",
    "validate:skills": "node scripts/validate-agent-skills.mjs",
    "sync:claude-hooks": "node scripts/sync-claude-plugin-hooks.mjs",
    "pack:dry-run": "npm_config_cache=/tmp/agent-workbench-npm-cache npm pack --dry-run --json",
    "rebuild:native": "node scripts/rebuild-native.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-trace-base": "^2.7.1",
    "@opentelemetry/sdk-trace-node": "^2.7.1",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "better-sqlite3": "^12.9.0",
    "tree-sitter": "^0.25.0",
    "tree-sitter-go": "^0.25.0",
    "tree-sitter-javascript": "^0.25.0",
    "tree-sitter-python": "^0.25.0",
    "tree-sitter-typescript": "^0.23.2",
    "tsx": "^4.20.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.0.0",
    "typescript": "^5.9.0",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "tree-sitter",
      "tree-sitter-go",
      "tree-sitter-javascript",
      "tree-sitter-python",
      "tree-sitter-typescript"
    ]
  }
}
