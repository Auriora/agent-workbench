{
  "mcpServers": {
    "agent-workbench": {
      "command": "node",
      "args": [
        "${AGENT_WORKBENCH_INSTALL_ROOT}/plugins/agent-workbench/mcp-launch.mjs"
      ],
      "env": {
        "AGENT_WORKBENCH_PROVIDER": "kiro",
        "AGENT_WORKBENCH_PROVIDER_PLUGIN_NAME": "agent-workbench"
      },
      "timeout": 120000
    }
  }
}
