{
  "enabled": true,
  "name": "Agent Workbench Ready Check",
  "description": "Adds quiet Agent Workbench availability context on demand.",
  "version": "1",
  "when": {
    "type": "userTriggered"
  },
  "then": {
    "type": "runCommand",
    "command": "AGENT_WORKBENCH_HOOK_FEEDBACK=basic node \"${AGENT_WORKBENCH_INSTALL_ROOT:-$HOME/.local/share/agent-workbench}/plugins/agent-workbench/kiro-power/hooks/session-start.js\""
  },
  "shortName": "agent-workbench-ready-check"
}
