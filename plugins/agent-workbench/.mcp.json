{
  "mcpServers": {
    "agent-workbench": {
      "command": "node",
      "args": [
        "${PLUGIN_ROOT}/mcp-launch.mjs"
      ],
      "env": {
        "AGENT_WORKBENCH_PROVIDER": "codex",
        "AGENT_WORKBENCH_PROVIDER_PLUGIN_NAME": "agent-workbench",
        "AGENT_WORKBENCH_PROVIDER_PLUGIN_VERSION": "0.6.1"
      },
      "startup_timeout_sec": 30.0
    }
  }
}
