{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "AGENT_WORKBENCH_HOOK_FEEDBACK=basic node \"${CLAUDE_PLUGIN_ROOT}/hooks/session-start.js\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "AGENT_WORKBENCH_HOOK_FEEDBACK=basic node \"${CLAUDE_PLUGIN_ROOT}/hooks/post-edit-feedback.js\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
