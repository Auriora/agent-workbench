{
  "enabled": true,
  "name": "Agent Workbench Post Write Feedback",
  "description": "Asks Kiro to run Agent Workbench feedback after write tools change files.",
  "version": "1",
  "when": {
    "type": "postToolUse",
    "toolTypes": [
      "write"
    ]
  },
  "then": {
    "type": "askAgent",
    "prompt": "A write tool just changed files. Use the Agent Workbench MCP runtime to inspect the changed files when they are available in the hook context. Prefer diagnostics_for_files for focused static feedback, then use verification_plan if broader validation guidance is needed. Keep the response brief and report only actionable findings."
  },
  "shortName": "agent-workbench-post-write-feedback"
}
